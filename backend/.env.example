# 服务器配置
SERVER_PORT=8567
SERVER_HOST=0.0.0.0

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=devink
DB_USER=root
DB_PASSWORD=123456

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Session 配置
SESSION_SECRET_KEY=your-secret-key-change-in-production
SESSION_MAX_AGE=2592000

# 密码加密盐值
PASSWORD_SALT=devink

# 初始化种子用户密码（admin / user / test 共用，明文）
INIT_ADMIN_PASSWORD=12345678

# AI 配置
DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_MODEL=qwen3-max

# Pexels 图片搜索
PEXELS_API_KEY=your-pexels-api-key

# 阿里云 OSS
ALICLOUD_OSS_SECRET_ID=your-oss-secret-id
ALICLOUD_OSS_SECRET_KEY=your-oss-secret-key
ALICLOUD_OSS_REGION=cn-hangzhou
ALICLOUD_OSS_BUCKET=your-bucket-name
ALICLOUD_OSS_DOMAIN=

# Nano Banana / Gemini AI 生图
# NANO_BANANA_API_KEY=your-gemini-api-key
# NANO_BANANA_MODEL=gemini-2.5-flash-image
# NANO_BANANA_ASPECT_RATIO=16:9

# 多智能体并行编排（并发数和失败策略）
AGENT_IMAGE_MAX_CONCURRENCY=3
AGENT_IMAGE_FAIL_FAST=true
